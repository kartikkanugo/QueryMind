  "version": "0.2.0",
  "configurations": [
    {
      "name": "src-server-win",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceRoot}/src-server/target/debug/src-server.exe",
      "args": ["-c", "env.toml"],
      "cwd": "${workspaceRoot}",
      "preLaunchTask": "cargo-build-task"
    },
    {
      "name": "src-server-linux",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceRoot}/src-server/target/debug/src-server",
      "args": ["-c", "env.toml"],
      "cwd": "${workspaceRoot}",
      "preLaunchTask": "cargo-build-task"
    }
  ]
}
